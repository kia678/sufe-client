{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xboard",
  "version": "0.1.0",
  "identifier": "com.xboard.client.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Xboard",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' blob: https://challenges.cloudflare.com https://www.google.com https://www.gstatic.com https://www.recaptcha.net; worker-src 'self' blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; frame-src https://challenges.cloudflare.com https://www.google.com https://www.recaptcha.net"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/mihomo"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Xboard 客户端",
    "longDescription": "Xboard 多平台代理客户端：基于 mihomo (Clash.Meta) 内核，支持运行时热更新与多内核扩展。",
    "publisher": "Xboard",
    "copyright": "Copyright © 2026 Xboard contributors",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": []
    },
    "windows": {
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ]
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libcap2-bin"
        ],
        "postInstallScript": "build_extras/postinst.sh"
      },
      "rpm": {
        "depends": [
          "libcap"
        ],
        "postInstallScript": "build_extras/postinst-rpm.sh"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://shannon-x.github.io/sufe-client/desktop/latest.json",
        "https://github.com/Shannon-x/sufe-client/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1RTQxRkRGOURFNzU3RDAKUldUUVYrZWQzeC9reFhOdUhCeVRNYlBSaVpMVCtuZDVJYnNhM3BJWHVFQ3VPUGVtQXZBbFRkOXYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
